# install [Task](https://taskfile.dev) task runner.
brew "go-task/tap/go-task"

# install Go and related tools.
brew "go"
brew "golangci-lint"
brew "golang-migrate"

# install Python version manager.
brew "uv"

# install Node version manager.
brew "nvm"

# other command line utilities.
brew "fzf"
brew "pinentry-mac"
